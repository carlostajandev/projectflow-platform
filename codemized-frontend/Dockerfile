# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile — Next.js Frontend (multi-stage)
#
# Stages:
#   1. deps        → install all dependencies
#   2. builder     → compile Next.js with standalone output
#   3. production  → minimal runtime image (no node_modules, no source)
#
# Requires next.config.mjs to have: output: 'standalone'
# ─────────────────────────────────────────────────────────────────────────────

# ─── Stage 1: Dependencies ────────────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm

# Copy manifests first to leverage Docker layer caching
COPY package.json pnpm-lock.yaml ./

# Install all dependencies (dev included — needed for Next.js build)
RUN pnpm install --frozen-lockfile

# ─── Stage 2: Build ───────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

RUN npm install -g pnpm

# Reuse installed node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy full source
COPY . .

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# Build Next.js — outputs to .next/standalone (requires output: 'standalone')
RUN pnpm run build

# ─── Stage 3: Production ──────────────────────────────────────────────────────
FROM node:20-alpine AS production

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create non-root user for security (never run as root in production)
RUN addgroup --system --gid 1001 nodejs
RUN adduser  --system --uid 1001 nextjs

# Copy public assets
COPY --from=builder /app/public ./public

# Copy standalone server output (self-contained Node.js server)
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./

# Copy static assets separately (required by standalone output)
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Run as non-root
USER nextjs

EXPOSE 3000
ENV PORT=3000

# server.js is generated by Next.js standalone output
CMD ["node", "server.js"]
